<Window x:Class="Thalamus.UI.CodePreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="C# Export Preview" Height="600" Width="700"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#1E1E2E"
        Foreground="#CCCCFF">

    <DockPanel>
        <!-- Button bar at bottom -->
        <Border DockPanel.Dock="Bottom" Background="#2A2A3E" Padding="12,8">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="CopyButton" Content="Copy" Width="80" Height="32" Margin="0,0,8,0"
                        Background="#2A2A3E" Foreground="#CCCCFF" BorderBrush="#555577"
                        BorderThickness="1" Cursor="Hand" Click="CopyButton_Click"/>
                <Button x:Name="SaveButton" Content="Save as .cs..." Width="100" Height="32" Margin="0,0,8,0"
                        Background="#2A2A3E" Foreground="#CCCCFF" BorderBrush="#555577"
                        BorderThickness="1" Cursor="Hand" Click="SaveButton_Click"/>
                <Button x:Name="CloseButton" Content="Close" Width="80" Height="32"
                        Background="#2A2A3E" Foreground="#CCCCFF" BorderBrush="#555577"
                        BorderThickness="1" Cursor="Hand" Click="CloseButton_Click"/>
            </StackPanel>
        </Border>

        <!-- Code display -->
        <TextBox x:Name="CodeTextBox"
                 IsReadOnly="True"
                 AcceptsReturn="True"
                 TextWrapping="NoWrap"
                 FontFamily="Consolas"
                 FontSize="10"
                 Background="#0D0D1A"
                 Foreground="#CCFFCC"
                 HorizontalScrollBarVisibility="Auto"
                 VerticalScrollBarVisibility="Auto"
                 Padding="8"/>
    </DockPanel>

</Window>
