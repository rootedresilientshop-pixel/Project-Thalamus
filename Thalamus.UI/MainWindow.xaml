<Window x:Class="Thalamus.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DreamCraft Thalamus" Height="720" Width="1280"
        Background="#1E1E2E"
        WindowStyle="None"
        AllowsTransparency="False"
        ResizeMode="CanResizeWithGrip">
  <WindowChrome.WindowChrome>
    <WindowChrome CaptionHeight="32" ResizeBorderThickness="5" UseAeroCaptionButtons="False"/>
  </WindowChrome.WindowChrome>
    <Window.Resources>
        <Style x:Key="ThalamusMenuStyle" TargetType="Menu">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#333333"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style x:Key="ThalamusMenuItemStyle" TargetType="MenuItem">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#333333"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,3"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#444444"/>
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- Custom title bar (replaces default chrome) -->
        <Grid DockPanel.Dock="Top" Height="32" Background="#12121E" WindowChrome.IsHitTestVisibleInChrome="False">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <!-- Title text -->
            <TextBlock Grid.Column="0" Text="DreamCraft Thalamus"
                       Foreground="#888899" FontSize="11"
                       VerticalAlignment="Center" Margin="12,0,0,0"
                       IsHitTestVisible="False"/>
            <!-- Window controls -->
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button x:Name="TitleMinimize" Content="─" Width="46" Height="32"
                        WindowChrome.IsHitTestVisibleInChrome="True"
                        Background="Transparent" Foreground="#AAAAAA" BorderThickness="0"
                        Click="TitleMinimize_Click"/>
                <Button x:Name="TitleMaximize" Content="□" Width="46" Height="32"
                        WindowChrome.IsHitTestVisibleInChrome="True"
                        Background="Transparent" Foreground="#AAAAAA" BorderThickness="0"
                        Click="TitleMaximize_Click"/>
                <Button x:Name="TitleClose" Content="✕" Width="46" Height="32"
                        WindowChrome.IsHitTestVisibleInChrome="True"
                        Background="Transparent" Foreground="#AAAAAA" BorderThickness="0"
                        Click="TitleClose_Click"/>
            </StackPanel>
        </Grid>

        <!-- File menu bar -->
        <Menu DockPanel.Dock="Top" Style="{StaticResource ThalamusMenuStyle}" ItemContainerStyle="{StaticResource ThalamusMenuItemStyle}">
            <MenuItem Header="File" x:Name="MenuFileRoot" Style="{StaticResource ThalamusMenuItemStyle}" ItemContainerStyle="{StaticResource ThalamusMenuItemStyle}">
                <MenuItem Header="New" InputGestureText="Ctrl+N" x:Name="MenuFileNew" Style="{StaticResource ThalamusMenuItemStyle}"/>
                <MenuItem Header="Open" InputGestureText="Ctrl+O" x:Name="MenuFileOpen" Style="{StaticResource ThalamusMenuItemStyle}"/>
                <Separator/>
                <MenuItem Header="Save" InputGestureText="Ctrl+S" x:Name="MenuFileSave" Style="{StaticResource ThalamusMenuItemStyle}"/>
                <MenuItem Header="Save As..." InputGestureText="Ctrl+Shift+S" x:Name="MenuFileSaveAs" Style="{StaticResource ThalamusMenuItemStyle}"/>
                <Separator/>
                <MenuItem Header="Export to C#..." x:Name="MenuFileExportCs" Style="{StaticResource ThalamusMenuItemStyle}"/>
            </MenuItem>
            <MenuItem Header="⚡ Pulse" InputGestureText="F5" x:Name="MenuPulse"
                      FontWeight="SemiBold" Style="{StaticResource ThalamusMenuItemStyle}"/>
            <MenuItem Header="Graph" x:Name="MenuGraphRoot" Style="{StaticResource ThalamusMenuItemStyle}" ItemContainerStyle="{StaticResource ThalamusMenuItemStyle}">
                <MenuItem Header="Auto-Layout Nodes" InputGestureText="Ctrl+L" x:Name="MenuGraphAutoLayout" Style="{StaticResource ThalamusMenuItemStyle}"/>
            </MenuItem>
            <MenuItem Header="Help" Style="{StaticResource ThalamusMenuItemStyle}" ItemContainerStyle="{StaticResource ThalamusMenuItemStyle}">
                <MenuItem Header="About Thalamus..." x:Name="MenuHelpAbout" Style="{StaticResource ThalamusMenuItemStyle}"/>
            </MenuItem>
        </Menu>

        <!-- Phase 13: Live Sync header bar -->
        <Border DockPanel.Dock="Top" Background="#1E1E2E"
                BorderBrush="#333355" BorderThickness="0,0,0,1" Padding="8,3">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <ToggleButton x:Name="LiveSyncToggle"
                              Content="⚡ Live Sync" Width="90" Height="22"
                              Background="#1A2A1A" Foreground="#F0F0F0"
                              BorderBrush="#336633" BorderThickness="1"
                              FontSize="10" Cursor="Hand"
                              ToolTip="Broadcast pulse results to localhost:9000 after every F5"/>
                <Button x:Name="DebugButton"
                        Content="DEBUG"
                        Width="60" Height="22"
                        Margin="8,0,0,0"
                        Background="#333333"
                        Foreground="#FFFFFF"
                        BorderBrush="#666666"
                        BorderThickness="1"
                        FontSize="10"
                        Click="DebugButton_Click"/>
            </StackPanel>
        </Border>

        <!-- Main grid with palette and canvas -->
        <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="264" />           <!-- Palette panel -->
            <ColumnDefinition Width="*" />              <!-- Canvas area -->
        </Grid.ColumnDefinitions>

        <!-- LEFT: Provider palette with search and grouping -->
        <Border Grid.Column="0" Background="#2A2A3E" BorderBrush="#444466"
                BorderThickness="0,0,1,0" Visibility="Visible" Panel.ZIndex="99">
            <TabControl Background="#2A2A3E" BorderThickness="0" TabStripPlacement="Top">
                <!-- TAB 1: Palette -->
                <TabItem Header="Palette" Background="#1E1E2E" Foreground="#DDDDFF">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Orientation="Vertical" Margin="6,6,6,0">
                            <StackPanel x:Name="BridgeModPanel" Orientation="Horizontal" Margin="0,0,0,4">
                                <Ellipse x:Name="BridgeModDot" Width="8" Height="8"
                                         Fill="#44CC44" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <Label Content="BridgeMod — Sovereign Module"
                                       Foreground="#CCCCCC" FontSize="10" Padding="0"/>
                            </StackPanel>
                            <StackPanel x:Name="KanonPanel" Orientation="Horizontal">
                                <Ellipse x:Name="KanonDot" Width="8" Height="8"
                                         Fill="#44CC44" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <Label Content="Kanon — Sovereign Module"
                                       Foreground="#CCCCCC" FontSize="10" Padding="0"/>
                            </StackPanel>
                        </StackPanel>
                        <!-- Header -->
                        <TextBlock DockPanel.Dock="Top" Text="Node Palette"
                                   Foreground="#FFFFFF" FontWeight="Bold"
                                   Margin="8,8,8,4" FontSize="13"/>

                        <!-- Search box: TextBox + placeholder + clear button -->
                        <Grid DockPanel.Dock="Top" Margin="6,4,6,6">
                            <TextBox x:Name="NodeSearchBox"
                                     Background="#12122A"
                                     Foreground="#DDDDFF"
                                     CaretBrush="#DDDDFF"
                                     BorderBrush="#555577"
                                     BorderThickness="1"
                                     Padding="6,4,22,4"
                                     FontSize="11"
                                     TextChanged="NodeSearchBox_TextChanged"
                                     KeyDown="NodeSearchBox_KeyDown"/>
                            <!-- Placeholder text (ghost) -->
                            <TextBlock x:Name="SearchPlaceholder"
                                       Text="Search Nodes..."
                                       Foreground="#555577"
                                       FontSize="11"
                                       Margin="8,0,0,0"
                                       IsHitTestVisible="False"
                                       VerticalAlignment="Center"/>
                            <!-- Clear (×) button -->
                            <Button x:Name="ClearSearchButton"
                                    Content="×"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Width="18" Height="18"
                                    Margin="0,0,2,0"
                                    FontSize="13"
                                    Background="Transparent"
                                    Foreground="#F0F0F0"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Visibility="Collapsed"
                                    Click="ClearSearchButton_Click"/>
                        </Grid>

                        <!-- Grouped, filtered palette list -->
                        <ListBox x:Name="PaletteList"
                                 Background="Transparent" BorderThickness="0"
                                 Foreground="#DDDDFF"
                                 SelectionChanged="PaletteList_SelectionChanged"
                                 MouseDoubleClick="PaletteList_MouseDoubleClick">

                            <!-- Category group headers -->
                            <ListBox.GroupStyle>
                                <GroupStyle>
                                    <GroupStyle.HeaderTemplate>
                                        <DataTemplate>
                                            <Border Background="#1E1E3A"
                                                    BorderBrush="#333355" BorderThickness="0,0,0,1"
                                                    Padding="6,6"
                                                    Margin="0,12,0,0">
                                                <TextBlock Text="{Binding Name}"
                                                           Foreground="#FFFFFF"
                                                           FontSize="10"
                                                           FontWeight="Bold"/>
                                            </Border>
                                        </DataTemplate>
                                    </GroupStyle.HeaderTemplate>
                                </GroupStyle>
                            </ListBox.GroupStyle>

                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Opacity" Value="1"/>
                                    <Setter Property="ToolTip" Value="{x:Null}"/>
                                    <Style.Triggers>
                                        <Trigger Property="Tag" Value="True">
                                            <Setter Property="Opacity" Value="0.5"/>
                                            <Setter Property="ToolTip" Value="Sovereign Tier Required. Visit rootedresilientshop.com to unlock."/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.ItemContainerStyle>

                            <!-- Node item template: Name + Description -->
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Vertical" Margin="4,2">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Name}"
                                                       Foreground="#FFFFFF"
                                                       FontWeight="SemiBold" FontSize="12"/>
                                            <TextBlock Text=" 🔒"
                                                       Foreground="#CCCCCC"
                                                       FontSize="11">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Tag}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Description}"
                                                   FontSize="9" Foreground="#E6E6F2"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                </TabItem>

                <!-- TAB 2: Node Nexus -->
                <TabItem Header="⬡ Node Nexus" Background="#1E1E2E" Foreground="#DDDDFF">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="Community Templates"
                                   Foreground="#FFFFFF" FontWeight="Bold"
                                   Margin="8,8,8,4" FontSize="13"/>

                        <!-- Action buttons row -->
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="6,4,6,4">
                            <Button x:Name="ImportTemplateButton" Content="⬇ Import Template"
                                    Width="120" Height="28" Margin="0,0,6,0"
                                    Background="#12122A" Foreground="#DDDDFF"
                                    BorderBrush="#444466" BorderThickness="1" FontSize="10"
                                    Click="ImportTemplateButton_Click"/>
                            <Button x:Name="ExportNexusButton" Content="⬆ Export to Nexus"
                                    Width="120" Height="28"
                                    Background="#12122A" Foreground="#DDDDFF"
                                    BorderBrush="#444466" BorderThickness="1" FontSize="10"
                                    Click="ExportNexusButton_Click"/>
                        </StackPanel>

                        <!-- Template list (placeholder) -->
                        <ListBox x:Name="NexusTemplateList" Background="Transparent" BorderThickness="0"
                                 Foreground="#DDDDFF" ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBoxItem Foreground="#888899">(Community templates coming in v1.1.0)</ListBoxItem>
                        </ListBox>

                        <!-- Footer guidance text -->
                        <TextBlock DockPanel.Dock="Bottom"
                                   Text="Share your logic freely or monetize your modules on itch.io. The Nexus is yours."
                                   Foreground="#555577" FontSize="9" TextWrapping="Wrap"
                                   Margin="8,4,8,8"/>
                    </DockPanel>
                </TabItem>
            </TabControl>
        </Border>

        <!-- RIGHT: Zoomable/pannable canvas -->
        <Border Grid.Column="1" ClipToBounds="True"
                x:Name="CanvasBorder" Background="#12121E"
                Panel.ZIndex="1">
            <Grid>
                <!-- ScaleTransform + TranslateTransform for zoom+pan -->
                <Canvas x:Name="GraphCanvas"
                        Background="Transparent"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        MinWidth="800"
                        MinHeight="600"
                        MouseDown="GraphCanvas_MouseDown"
                        MouseMove="GraphCanvas_MouseMove"
                        MouseUp="GraphCanvas_MouseUp"
                        MouseWheel="GraphCanvas_MouseWheel">
                    <Canvas.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform x:Name="CanvasScale" ScaleX="1" ScaleY="1"/>
                            <TranslateTransform x:Name="CanvasTranslate" X="0" Y="0"/>
                        </TransformGroup>
                    </Canvas.RenderTransform>
                </Canvas>

                <!-- Welcome overlay (first launch) -->
                <Grid x:Name="WelcomeOverlay" Background="#CC12121E" Visibility="Collapsed"
                      Panel.ZIndex="20">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="40">
                        <TextBlock Text="Welcome to Thalamus" Foreground="#FFFFFF"
                                   FontSize="28" FontWeight="Bold" TextAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Text="A sovereign visual logic engine for the DreamCraft ecosystem."
                                   Foreground="#888899" FontSize="13" TextAlignment="Center" Margin="0,0,0,32"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button x:Name="WelcomeLoadStarterButton" Content="⬇ Load Starter Project"
                                    Width="200" Height="40" Margin="0,0,12,0"
                                    Background="#1A2A1A" Foreground="#CCFFCC"
                                    BorderBrush="#336633" BorderThickness="1" FontSize="13"
                                    Click="WelcomeLoadStarter_Click"/>
                            <Button x:Name="WelcomeNexusButton" Content="⬡ Visit Node Nexus"
                                    Width="200" Height="40"
                                    Background="#1A1A2A" Foreground="#CCCCFF"
                                    BorderBrush="#333366" BorderThickness="1" FontSize="13"
                                    Click="WelcomeNexus_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
        </Grid>

        <!-- Phase 12: Status Bar -->
        <Border DockPanel.Dock="Bottom" Background="#1A1A2E"
                BorderBrush="#333355" BorderThickness="0,1,0,0" Padding="8,3">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="StatusRamText"   Text="RAM: --"        Foreground="#666688"
                           FontSize="10" FontFamily="Consolas" Margin="0,0,20,0"/>
                <TextBlock x:Name="StatusSentryText" Text="Sentry: --" Foreground="#66CC66"
                           FontSize="10" FontFamily="Consolas" Margin="0,0,20,0"/>
                <TextBlock x:Name="StatusPulseStateText" Text="Pulse: --" Foreground="#66CC66"
                           FontSize="10" FontFamily="Consolas" Margin="0,0,20,0"/>
                <TextBlock x:Name="StatusPulseText" Text="Last Pulse: --" Foreground="#666688"
                           FontSize="10" FontFamily="Consolas"/>
                <TextBlock x:Name="StatusSyncText"
                           Text="Trial Sync Session ended. Re-toggle to resume or go Pro for unlimited sync."
                           Foreground="#FF9966"
                           FontSize="10" FontFamily="Consolas"
                           Margin="20,0,0,0"
                           Visibility="Collapsed"/>
            </StackPanel>
        </Border>
    </DockPanel>
</Window>
