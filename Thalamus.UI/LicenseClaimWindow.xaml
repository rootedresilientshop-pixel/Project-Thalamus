<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="Thalamus.UI.LicenseClaimWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Claim Thalamus License"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E"
        Foreground="#E0E0E0"
        Width="600"
        Height="500"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid Background="#1E1E1E">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="520">
            <!-- Title -->
            <TextBlock Text="🔐 Claim Your Thalamus License"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="#00E5FF"
                       Margin="0,0,0,20"
                       TextAlignment="Center"/>

            <!-- Status Message -->
            <TextBlock Name="StatusMessage"
                       FontSize="12"
                       Foreground="#A0A0A0"
                       TextWrapping="Wrap"
                       Margin="0,0,0,15"
                       Text="Enter your purchase code to unlock premium features."/>

            <!-- Purchase Code Input -->
            <TextBlock Text="Purchase Code:"
                       FontSize="12"
                       Foreground="#E0E0E0"
                       Margin="0,0,0,5"/>
            <TextBox Name="PurchaseCodeInput"
                     Height="40"
                     Padding="10"
                     FontSize="12"
                     Background="#2D2D2D"
                     Foreground="#E0E0E0"
                     BorderBrush="#404040"
                     BorderThickness="1"
                     Margin="0,0,0,20"/>

            <!-- Module Selection -->
            <TextBlock Text="Module to Unlock:"
                       FontSize="12"
                       Foreground="#E0E0E0"
                       Margin="0,0,0,5"/>
            <ComboBox Name="ModuleSelection"
                      Height="40"
                      Padding="10"
                      FontSize="12"
                      Background="#2D2D2D"
                      Foreground="#E0E0E0"
                      BorderBrush="#404040"
                      BorderThickness="1"
                      Margin="0,0,0,20">
                <ComboBoxItem>BridgeMod SDK</ComboBoxItem>
                <ComboBoxItem>Kanon Kernel</ComboBoxItem>
                <ComboBoxItem>Full Suite</ComboBoxItem>
            </ComboBox>

            <!-- Progress Indicator -->
            <ProgressBar Name="ProgressIndicator"
                        Height="4"
                        Background="#404040"
                        Foreground="#00E5FF"
                        IsIndeterminate="False"
                        Visibility="Collapsed"
                        Margin="0,0,0,20"/>

            <!-- Hardware Info (Read-only) -->
            <TextBlock Text="Your Hardware ID (bound to this key):"
                       FontSize="10"
                       Foreground="#808080"
                       Margin="0,0,0,5"/>
            <TextBlock Name="HardwareInfoDisplay"
                       FontSize="9"
                       Foreground="#606060"
                       Background="#2D2D2D"
                       Padding="8"
                       Text="[Detecting hardware...]"
                       TextWrapping="Wrap"
                       MinHeight="60"
                       Margin="0,0,0,15"/>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Name="CancelButton"
                        Content="Cancel"
                        Width="100"
                        Height="40"
                        Background="#404040"
                        Foreground="#E0E0E0"
                        BorderBrush="#505050"
                        BorderThickness="1"
                        Click="OnCancelClick"
                        Margin="0,0,10,0"/>
                <Button Name="ClaimButton"
                        Content="Claim License"
                        Width="150"
                        Height="40"
                        Background="#00A8CC"
                        Foreground="#FFFFFF"
                        BorderBrush="#0088AA"
                        BorderThickness="1"
                        Click="OnClaimClick"
                        FontWeight="Bold"/>
            </StackPanel>

            <!-- Error Display -->
            <TextBlock Name="ErrorMessage"
                       FontSize="10"
                       Foreground="#FF6B6B"
                       TextWrapping="Wrap"
                       Visibility="Collapsed"
                       Margin="0,15,0,0"/>
        </StackPanel>
    </Grid>
</Window>
